# Fastify server port
PORT=4000
HOST=0.0.0.0
PUBLIC_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dev database (Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ops_db

# Symmetric key placeholder for encryption at rest (replace in prod)
ENCRYPTION_KEY=dev-smartwork-change-me

# JWT secret
JWT_SECRET=dev-smartwork-jwt-secret

# OpenAI (for autofill AI answers)
OPENAI_API_KEY=
OPENAI_AUTOFILL_MODEL=gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini
